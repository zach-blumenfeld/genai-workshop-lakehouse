# Claude Code auth: leave blank if signed in; otherwise use the workshop key or your own
ANTHROPIC_API_KEY=

# Neo4j sandbox - paste the credentials from the workshop
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# BigQuery warehouse - read-only; the workshop's AutoFix dataset is pre-wired
GCP_PROJECT_ID=neo4jeventdemos
BIGQUERY_DATASET_ID=autofix_service
# BigQuery auth: paste the one-line read-only key from the workshop slides.
# (If you leave this blank, your own `gcloud auth application-default login` is used.)
BIGQUERY_SA_KEY_B64=

# Optional: stand the AutoFix data up on Databricks (Genie + AI Search) - see databricks/
# DATABRICKS_SERVER_HOSTNAME=
# DATABRICKS_HTTP_PATH=
# DATABRICKS_TOKEN=
# DATABRICKS_CATALOG=lakehouse-workshop
# DATABRICKS_SCHEMA=autofix_service
